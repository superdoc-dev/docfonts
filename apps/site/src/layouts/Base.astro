---
// Self-hosted UI fonts (Fontsource). docfonts is not a webfont host: no CDN, no substitute webfonts.
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/700.css";
import "../styles/tokens.css";

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Measured open substitutes for proprietary document fonts, with advance deltas, face coverage, license provenance, and a verdict.",
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site">
      <div class="wrap bar">
        <a class="logo" href="/"><span class="tick"></span>docfonts</a>
        <nav class="site">
          <a class="navlink" href="/fonts/calibri">Fonts</a>
          <a class="navlink" href="/tools/scan-docx-fonts">Scanner</a>
          <a class="navlink" href="https://github.com/superdoc-dev/docfonts">GitHub</a>
          <span class="sd">Built by <b>SuperDoc</b></span>
        </nav>
      </div>
    </header>
    <main class="wrap"><slot /></main>
    <footer class="site">
      <div class="wrap foot">
        <div>
          <b>docfonts</b> · the measured registry of document-font substitution. No proprietary binaries,
          ever.
        </div>
        <div class="sd2">Built by the team behind <b>SuperDoc</b>. Standalone and neutral.</div>
      </div>
    </footer>
  </body>
</html>
