---
import type { FaceCoverage } from "@docfonts/core";

interface Props {
  faces: FaceCoverage;
  /** dim the grid when face coverage is not assessed (category fallbacks, no-substitute). */
  muted?: boolean;
}
const { faces, muted = false } = Astro.props;
const cells: [string, boolean][] = [
  ["R", faces.regular],
  ["B", faces.bold],
  ["I", faces.italic],
  ["BI", faces.boldItalic],
];
---

<span class="faces" style={muted ? "opacity:.32" : undefined}>
  {cells.map(([label, on]) => <span class={`face ${on ? "on" : "off"}`}>{label}</span>)}
</span>
