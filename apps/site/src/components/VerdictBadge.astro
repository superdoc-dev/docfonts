---
import type { Verdict } from "@docfonts/core";
import { VERDICT_META } from "../lib/verdict";

interface Props {
  verdict: Verdict;
  /** mark the verdict as qualified (per-face verdicts differ from this top-level one). */
  qualified?: boolean;
}
const { verdict, qualified = false } = Astro.props;
const m = VERDICT_META[verdict];
---

<span class={`badge ${m.cls}`}><span class="g" aria-hidden="true">{m.glyph}</span>{m.label}</span>{
  qualified && (
    <span class="qualified" title="Per-face verdicts differ; see the face breakdown.">qualified</span>
  )
}

<style>
  .qualified {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--v-cell);
    border: 1px solid #b4530940;
    background: #b4530910;
    border-radius: 5px;
    padding: 3px 6px;
    margin-left: 6px;
    vertical-align: middle;
  }
</style>
