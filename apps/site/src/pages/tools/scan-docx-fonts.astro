---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Scan a .docx for fonts | docfonts"
  description="See every font a .docx declares, and what can stand in for each. Runs entirely in your browser - the file never uploads."
>
  <section class="head">
    <div class="eyebrow">In-browser scanner</div>
    <h1>Scan a .docx for fonts.</h1>
    <p class="lead">
      See every font a document declares, and the measured verdict for each. The file is parsed
      locally in your browser and never uploads.
    </p>
  </section>

  <section>
    <label class="drop" id="drop">
      <input type="file" id="file" accept=".docx" hidden />
      <div class="dz-title">Drop a .docx here, or choose a file</div>
      <div class="dz-sub mono">nothing leaves this page</div>
    </label>
    <div id="out" class="out" hidden></div>
  </section>
</Base>

<script>
  const input = document.getElementById("file") as HTMLInputElement;
  const drop = document.getElementById("drop") as HTMLLabelElement;
  const out = document.getElementById("out") as HTMLDivElement;

  async function handle(file: File) {
    // Read locally only. This never performs a network request - that is the whole point.
    const bytes = new Uint8Array(await file.arrayBuffer());
    const kb = (bytes.byteLength / 1024).toFixed(1);
    out.hidden = false;
    out.innerHTML = `
      <div class="card">
        <div class="fn">${file.name}</div>
        <div class="meta mono">${kb} KB · read locally · not uploaded</div>
        <p class="todo">
          Font extraction is being wired up (the <code>@docfonts/docx-fonts</code> parser reads
          <code>[Content_Types].xml</code>, <code>word/theme/theme1.xml</code>, and <code>w:rFonts</code>).
          Once it lands, each declared font is matched to its measured registry verdict here, still
          entirely in your browser.
        </p>
      </div>`;
  }

  input.addEventListener("change", () => {
    const f = input.files?.[0];
    if (f) handle(f);
  });
  ["dragover", "dragenter"].forEach((e) =>
    drop.addEventListener(e, (ev) => {
      ev.preventDefault();
      drop.classList.add("over");
    }),
  );
  ["dragleave", "drop"].forEach((e) =>
    drop.addEventListener(e, () => drop.classList.remove("over")),
  );
  drop.addEventListener("drop", (ev) => {
    ev.preventDefault();
    const f = ev.dataTransfer?.files?.[0];
    if (f) handle(f);
  });
</script>

<style>
  .head {
    padding: 40px 0 8px;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    font-size: clamp(30px, 5.4vw, 44px);
    letter-spacing: -0.03em;
    margin: 10px 0 0;
  }
  .lead {
    color: var(--ink2);
    max-width: 60ch;
    margin-top: 14px;
    font-size: 17px;
  }
  .drop {
    display: block;
    border: 1.5px dashed var(--line);
    border-radius: 14px;
    background: var(--surface);
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .drop.over,
  .drop:hover {
    border-color: var(--accent);
  }
  .dz-title {
    font-size: 17px;
    font-weight: 600;
  }
  .dz-sub {
    font-size: 12px;
    color: var(--ink3);
    margin-top: 6px;
  }
  .out {
    margin-top: 16px;
  }
  .out :global(.card) {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px 20px;
  }
  .out :global(.fn) {
    font-weight: 600;
    font-size: 16px;
  }
  .out :global(.meta) {
    font-size: 12px;
    color: var(--ink3);
    margin-top: 4px;
  }
  .out :global(.todo) {
    color: var(--ink2);
    font-size: 13.5px;
    margin-top: 12px;
    line-height: 1.6;
  }
  .out :global(code) {
    font-family: var(--mono);
    font-size: 12px;
    background: var(--paper);
    padding: 1px 5px;
    border-radius: 4px;
  }
</style>
