---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Scan a .docx for fonts | docfonts"
  description="See the fonts a .docx declares - across its text, styles, headers and footers, footnotes, endnotes, comments, and theme - and what can stand in for each. Runs entirely in your browser; the file never uploads."
>
  <section class="head">
    <div class="eyebrow">In-browser scanner</div>
    <h1>Scan a .docx for fonts.</h1>
    <p class="lead">
      See the fonts a document declares - across its text, styles, headers and footers, footnotes,
      endnotes, comments, and theme - with the measured verdict for each. The file is parsed locally
      in your browser and never uploads.
    </p>
  </section>

  <section>
    <label class="drop" id="drop">
      <input type="file" id="file" accept=".docx" hidden />
      <div class="dz-title">Drop a .docx here, or choose a file</div>
      <div class="dz-sub mono">nothing leaves this page</div>
    </label>
    <div id="out" class="out" hidden></div>
  </section>
</Base>

<script>
  import { scanDocxFonts } from "@docfonts/docx-fonts";
  import { findByOriginal, loadRecords } from "@docfonts/registry";
  import { VERDICT_META, noCandidateLabel } from "../../lib/verdict";

  const input = document.getElementById("file") as HTMLInputElement;
  const drop = document.getElementById("drop") as HTMLLabelElement;
  const out = document.getElementById("out") as HTMLDivElement;
  const records = loadRecords();

  const esc = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

  function badge(verdict: keyof typeof VERDICT_META, qualified: boolean) {
    const m = VERDICT_META[verdict];
    const q = qualified
      ? ` <span class="qualified" title="Per-face verdicts differ; see the font page.">qualified</span>`
      : "";
    return `<span class="badge ${m.cls}"><span class="g" aria-hidden="true">${m.glyph}</span>${m.label}</span>${q}`;
  }

  function isQualified(rec: (typeof records)[number]): boolean {
    const fv = rec.faceVerdicts;
    if (!fv) return false;
    return Object.values(fv).some((v) => v && v !== rec.verdict);
  }

  function row(name: string, role: string) {
    const rec = findByOriginal(records, name)[0];
    const sub = rec?.candidate?.candidateFamily;
    const verdictCell = rec
      ? badge(rec.verdict as keyof typeof VERDICT_META, isQualified(rec))
      : `<span class="unknown">not measured yet</span>`;
    const subCell = rec
      ? sub
        ? esc(sub)
        : `<span class='dash'>${esc(noCandidateLabel(rec.verdict))}</span>`
      : "<span class='dash'>-</span>";
    return `<tr><td class="fam">${esc(name)}${role ? `<span class="role">${role}</span>` : ""}</td>
      <td class="sub">${subCell}</td><td>${verdictCell}</td></tr>`;
  }

  async function handle(file: File) {
    // Read locally only. This never performs a network request - that is the whole point.
    const bytes = new Uint8Array(await file.arrayBuffer());
    const kb = (bytes.byteLength / 1024).toFixed(1);
    out.hidden = false;

    let usage: ReturnType<typeof scanDocxFonts>;
    try {
      usage = scanDocxFonts(bytes);
    } catch (e) {
      out.innerHTML = `<div class="card"><div class="fn">${esc(file.name)}</div>
        <div class="meta mono">${kb} KB · read locally · not uploaded</div>
        <p class="err">Could not read this file as a .docx: ${esc((e as Error).message)}</p></div>`;
      return;
    }

    const roleOf = (f: string) =>
      f === usage.theme?.major ? "theme heading" : f === usage.theme?.minor ? "theme body" : "";
    const rows = usage.declared.map((f) => row(f, roleOf(f))).join("");
    const n = usage.declared.length;
    out.innerHTML = `<div class="card">
      <div class="fn">${esc(file.name)}</div>
      <div class="meta mono">${kb} KB · ${n} font${n === 1 ? "" : "s"} · read locally · not uploaded</div>
      <table class="restbl"><thead><tr><th>Font in document</th><th>Open substitute</th><th>Verdict</th></tr></thead>
        <tbody>${rows}</tbody></table>
    </div>`;
  }

  input.addEventListener("change", () => {
    const f = input.files?.[0];
    if (f) handle(f);
  });
  ["dragover", "dragenter"].forEach((e) =>
    drop.addEventListener(e, (ev) => {
      ev.preventDefault();
      drop.classList.add("over");
    }),
  );
  ["dragleave", "drop"].forEach((e) =>
    drop.addEventListener(e, () => drop.classList.remove("over")),
  );
  drop.addEventListener("drop", (ev) => {
    ev.preventDefault();
    const f = ev.dataTransfer?.files?.[0];
    if (f) handle(f);
  });
</script>

<style>
  .head {
    padding: 40px 0 8px;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  h1 {
    font-size: clamp(30px, 5.4vw, 44px);
    letter-spacing: -0.03em;
    margin: 10px 0 0;
  }
  .lead {
    color: var(--ink2);
    max-width: 60ch;
    margin-top: 14px;
    font-size: 17px;
  }
  .drop {
    display: block;
    border: 1.5px dashed var(--line);
    border-radius: 14px;
    background: var(--surface);
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .drop.over,
  .drop:hover {
    border-color: var(--accent);
  }
  .dz-title {
    font-size: 17px;
    font-weight: 600;
  }
  .dz-sub {
    font-size: 12px;
    color: var(--ink3);
    margin-top: 6px;
  }
  .out {
    margin-top: 16px;
  }
  .out :global(.card) {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px 20px;
  }
  .out :global(.fn) {
    font-weight: 600;
    font-size: 16px;
  }
  .out :global(.meta) {
    font-size: 12px;
    color: var(--ink3);
    margin-top: 4px;
  }
  .out :global(.err) {
    color: var(--v-clay);
    font-size: 13.5px;
    margin-top: 12px;
  }
  .out :global(.restbl) {
    width: 100%;
    border-collapse: collapse;
    margin-top: 14px;
  }
  .out :global(.restbl th) {
    text-align: left;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink3);
    font-weight: 500;
    padding: 6px 12px 6px 0;
    border-bottom: 1px solid var(--hair);
  }
  .out :global(.restbl td) {
    padding: 10px 12px 10px 0;
    border-bottom: 1px solid var(--hair);
    font-size: 14px;
    vertical-align: middle;
  }
  .out :global(.restbl tr:last-child td) {
    border-bottom: none;
  }
  .out :global(.restbl .fam) {
    font-weight: 600;
  }
  .out :global(.restbl .role) {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink3);
    margin-left: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .out :global(.restbl .sub) {
    color: var(--ink2);
  }
  .out :global(.restbl .dash) {
    color: var(--ink3);
  }
  .out :global(.restbl .unknown) {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink3);
  }
  .out :global(.qualified) {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--v-cell);
    border: 1px solid #b4530940;
    background: #b4530910;
    border-radius: 5px;
    padding: 3px 6px;
    margin-left: 6px;
  }
</style>
