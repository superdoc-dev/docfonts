---
import type { EvidenceRecord } from "@docfonts/registry";
import { loadRecords } from "@docfonts/registry";
import Base from "../layouts/Base.astro";
import FaceGrid from "../components/FaceGrid.astro";
import VerdictBadge from "../components/VerdictBadge.astro";
import { VERDICT_META, VERDICT_ORDER, isQualified, noCandidateLabel, pct } from "../lib/verdict";

const records = loadRecords();

// Lead with the honest no.
const featured = records.find((r) => r.verdict === "no_substitute");
// A real measured pass, for the specimen section.
const pass = records.find((r) => r.evidenceId === "calibri");

// Registry table: by verdict order, then name.
const ordered: EvidenceRecord[] = [...records].sort(
  (a, b) =>
    VERDICT_ORDER.indexOf(a.verdict) - VERDICT_ORDER.indexOf(b.verdict) ||
    a.originalFont.localeCompare(b.originalFont),
);

function advText(r: EvidenceRecord): string | null {
  return r.advance ? `${pct(r.advance.meanDelta)} / ${pct(r.advance.maxDelta)}` : null;
}
---

<Base title="docfonts - document font substitution, measured">
  <section class="hero">
    <div class="eyebrow">Measured font registry</div>
    <h1>Document font substitution, measured.</h1>
    <p class="lede">
      Open substitutes for proprietary document fonts, with advance deltas, face coverage, license
      provenance, and a verdict. Including when no open font stands in.
    </p>
    <div class="cta">
      <a href="/tools/scan-docx-fonts" class="btn p">Scan a .docx</a>
      <a href="#registry" class="btn s">Browse the registry</a>
      <span class="priv">runs in your browser · nothing uploads</span>
    </div>
  </section>

  {
    featured && (
      <section>
        <div class="lbl">Featured verdict</div>
        <div class="feat">
          <div class="body">
            <div class="q">
              <b>{featured.originalFont}</b> &rarr; no open metric substitute found.
            </div>
            {featured.notes && <div class="meta">{featured.notes}</div>}
          </div>
          <VerdictBadge verdict={featured.verdict} />
        </div>
      </section>
    )
  }

  {
    pass && (
      <section>
        <div class="lbl">What a measured pass looks like</div>
        <div class="spec">
          <div class="top">
            <div class="pair">
              {pass.originalFont} &rarr; <b>{pass.candidate?.candidateFamily}</b>
            </div>
            <VerdictBadge verdict={pass.verdict} />
          </div>
          <div class="swatchline">Headers intact. <span class="gray">Tables aligned.</span></div>
          <div class="readout">
            {advText(pass) && (
              <span>
                <span class="k">advance &Delta;</span> <span class="v">{advText(pass)}</span>
              </span>
            )}
            <span>
              <span class="k">faces</span> <span class="v">4 / 4</span>
            </span>
            {pass.candidateLicense && (
              <span>
                <span class="k">license</span> <span class="v">{pass.candidateLicense}</span>
              </span>
            )}
            {pass.measuredDate && (
              <span>
                <span class="k">measured</span> <span class="v">{pass.measuredDate}</span> · analytic-hmtx
              </span>
            )}
          </div>
          <div class="specnote">
            Specimen rendered in the UI font. A build-time image of the real substitute is planned;
            docfonts does not load substitute webfonts.
          </div>
        </div>
      </section>
    )
  }

  <section id="registry">
    <div class="lbl">Registry · measured sample</div>
    <div class="tblwrap">
      <table class="tbl">
        <thead>
          <tr>
            <th>Proprietary</th>
            <th>Open substitute</th>
            <th>&Delta; mean / max</th>
            <th>R&nbsp;B&nbsp;I&nbsp;BI</th>
            <th>License</th>
            <th>Verdict</th>
          </tr>
        </thead>
        <tbody>
          {
            ordered.map((r) => (
              <tr>
                <td class="fam">
                  <a href={`/fonts/${r.evidenceId}`}>{r.originalFont}</a>
                </td>
                <td class={r.candidate ? "sub" : "sub na"}>
                  {r.candidate ? r.candidate.candidateFamily : noCandidateLabel(r.verdict)}
                </td>
                <td class={advText(r) ? "num" : "num na"}>
                  {advText(r) ? (
                    <Fragment>
                      {pct(r.advance!.meanDelta)} <span class="max">/ {pct(r.advance!.maxDelta)}</span>
                    </Fragment>
                  ) : (
                    "-"
                  )}
                </td>
                <td>
                  <FaceGrid faces={r.faces} muted={r.verdict !== "metric_safe"} />
                </td>
                <td class="lic">{r.candidateLicense ?? "-"}</td>
                <td>
                  <VerdictBadge verdict={r.verdict} qualified={isQualified(r)} />
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <div class="lbl">The verdict taxonomy</div>
    <div class="legend">
      {
        VERDICT_ORDER.map((v) => (
          <div class="lg">
            <VerdictBadge verdict={v} />
            <div class="def">{VERDICT_META[v].def}</div>
          </div>
        ))
      }
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 78px 0 50px;
  }
  @media (max-width: 560px) {
    .hero {
      padding: 50px 0 36px;
    }
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }
  h1 {
    font-size: clamp(33px, 6.2vw, 54px);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 16px 0 0;
    max-width: 15ch;
    overflow-wrap: break-word;
  }
  .lede {
    font-size: clamp(16px, 2.4vw, 19px);
    color: var(--ink2);
    max-width: 60ch;
    margin-top: 20px;
    overflow-wrap: break-word;
  }
  .cta {
    display: flex;
    gap: 12px;
    margin-top: 28px;
    align-items: center;
    flex-wrap: wrap;
  }
  .priv {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink2);
  }

  .feat {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px 24px;
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .feat .body {
    flex: 1 1 260px;
    min-width: 0;
  }
  .feat .q {
    font-size: clamp(19px, 3.4vw, 23px);
    font-weight: 600;
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }
  .feat .meta {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink2);
    margin-top: 8px;
    overflow-wrap: anywhere;
    line-height: 1.6;
  }

  .spec {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    max-width: 100%;
  }
  .spec .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 13px 22px;
    border-bottom: 1px solid var(--hair);
    flex-wrap: wrap;
  }
  .spec .pair {
    flex: 1 1 200px;
    min-width: 0;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink2);
    overflow-wrap: anywhere;
  }
  .spec .pair b {
    color: var(--ink);
  }
  .spec .swatchline {
    padding: 28px 22px 8px;
    font-size: clamp(27px, 6vw, 46px);
    line-height: 1.12;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
  }
  .spec .swatchline .gray {
    color: var(--ink3);
  }
  .spec .readout {
    padding: 13px 22px;
    border-top: 1px solid var(--hair);
    display: flex;
    gap: 14px 18px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink2);
  }
  .spec .readout .k {
    color: var(--ink3);
  }
  .spec .readout .v {
    color: var(--ink);
    font-weight: 500;
  }
  .spec .specnote {
    padding: 0 22px 16px;
    font-size: 11.5px;
    color: var(--ink3);
  }

  .legend {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 12px;
  }
  .lg {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 13px 15px;
  }
  .lg .def {
    font-size: 13px;
    color: var(--ink2);
    margin-top: 9px;
    line-height: 1.5;
  }
</style>
