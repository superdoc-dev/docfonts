---
import type { EvidenceRecord } from "@docfonts/registry";
import { loadRecords } from "@docfonts/registry";
import FaceGrid from "../../components/FaceGrid.astro";
import VerdictBadge from "../../components/VerdictBadge.astro";
import Base from "../../layouts/Base.astro";
import { FACE_ORDER, VERDICT_META, isQualified, pct } from "../../lib/verdict";

// One canonical static page per PROPRIETARY font (the SEO surface). People search the proprietary
// name, so the title carries it. No split /fonts and /pairs - avoid keyword cannibalization.
export function getStaticPaths() {
  return loadRecords().map((r) => ({ params: { font: r.evidenceId }, props: { record: r } }));
}

interface Props {
  record: EvidenceRecord;
}
const { record } = Astro.props;
const m = VERDICT_META[record.verdict];
const sub = record.candidate?.candidateFamily ?? null;

// Headline copy branches by verdict, not just candidate presence: policy verdicts make NO measured
// claim, so they must not say "measured: no open clone".
const kind: "substitute" | "no_substitute" | "preserve_only" | "customer_supplied" = sub
  ? "substitute"
  : record.verdict === "preserve_only"
    ? "preserve_only"
    : record.verdict === "customer_supplied"
      ? "customer_supplied"
      : "no_substitute";

const HEAD = {
  substitute: {
    eyebrow: "Measured substitute",
    lead: null, // rendered with the substitute name below
    title: `${record.originalFont} open substitute: ${sub} (${m.label}) | docfonts`,
    description: `Measured: ${sub} as an open substitute for ${record.originalFont}. Verdict ${m.label}, with advance deltas, face coverage, and license provenance.`,
  },
  no_substitute: {
    eyebrow: "Measured result",
    lead: "No open metric clone.",
    title: `${record.originalFont}: no open metric substitute | docfonts`,
    description: `Measured: no open metric clone for ${record.originalFont}. The honest no, with method and date.`,
  },
  preserve_only: {
    eyebrow: "Policy",
    lead: "Preserve the original. Do not substitute.",
    title: `${record.originalFont}: preserve the original font | docfonts`,
    description: `${record.originalFont} should not be substituted - a stand-in would show wrong glyphs. Keep the original font name.`,
  },
  customer_supplied: {
    eyebrow: "Policy",
    lead: "Customer-supplied font required.",
    title: `${record.originalFont}: customer-supplied font | docfonts`,
    description: `No measured open substitute for ${record.originalFont}. Policy: use a customer-supplied font, else a reported visual/category fallback.`,
  },
}[kind];
const title = HEAD.title;
const description = HEAD.description;

const gateRows: [string, string][] = [
  ["static", record.gates.static],
  ["metric", record.gates.metric],
  ["layout", record.gates.layout],
  ["ship", record.gates.ship],
];

const measured = record.measurementRefs.length > 0;
const qualified = isQualified(record);
const faceRows = record.faceVerdicts
  ? FACE_ORDER.filter((f) => record.faceVerdicts?.[f]).map((f) => ({
      face: f,
      verdict: record.faceVerdicts?.[f],
    }))
  : [];
---

<Base title={title} description={description}>
  <section class="head">
    <a class="back" href="/#registry">&larr; registry</a>
    <div class="eyebrow">{HEAD.eyebrow}</div>
    <h1>{record.originalFont}</h1>
    <div class="lead">
      {
        sub ? (
          <Fragment>
            Open substitute: <b>{sub}</b>
          </Fragment>
        ) : (
          HEAD.lead
        )
      }
      <VerdictBadge verdict={record.verdict} qualified={qualified} />
    </div>
    {record.notes && <p class="notes">{record.notes}</p>}
  </section>

  {
    faceRows.length > 0 && (
      <section>
        <div class="lbl">Per-face verdict</div>
        <div class="faceverdicts">
          {faceRows.map(({ face, verdict }) => (
            <div class="fv">
              <span class="fvname mono">{face}</span>
              <VerdictBadge verdict={verdict as Props["record"]["verdict"]} />
            </div>
          ))}
        </div>
        {record.glyphExceptions && record.glyphExceptions.length > 0 && (
          <ul class="exceptions">
            {record.glyphExceptions.map((e) => (
              <li>
                <span class="mono">
                  {e.styleKey} · U+{e.codepoint.toString(16).toUpperCase().padStart(4, "0")} · &Delta;{" "}
                  {pct(e.advanceDelta)}
                </span>
                <span class="exnote">{e.note}</span>
              </li>
            ))}
          </ul>
        )}
        <p class="fineprint">
          Per-face verdicts are authoritative. The headline verdict ({VERDICT_META[record.verdict].label})
          is the <b>worst face</b>, so the summary never over-claims; the stronger faces above are better
          than the headline. This substitute is not uniformly {VERDICT_META[record.verdict].label}.
        </p>
      </section>
    )
  }

  {
    measured ? (
      <section>
        <div class="lbl">The measurement</div>
        <div class="facts">
          <div class="fact">
            <div class="k">advance &Delta; (mean / max)</div>
            <div class="v mono">
              {record.advance
                ? `${pct(record.advance.meanDelta)} / ${pct(record.advance.maxDelta)}`
                : "-"}
            </div>
          </div>
          <div class="fact">
            <div class="k">face coverage</div>
            <div class="v">
              <FaceGrid faces={record.faces} muted={record.verdict !== "metric_safe"} />
            </div>
          </div>
          <div class="fact">
            <div class="k">license</div>
            <div class="v mono">{record.candidateLicense ?? "-"}</div>
          </div>
          <div class="fact">
            <div class="k">measured</div>
            <div class="v mono">{record.measuredDate ?? "-"} · analytic-hmtx</div>
          </div>
        </div>
      </section>
    ) : (
      <section>
        <div class="lbl">Policy</div>
        <p class="notes">
          This is a policy row, not a measured comparison. {description}
        </p>
      </section>
    )
  }

  <section>
    <div class="lbl">Gates</div>
    <div class="gates">
      {
        gateRows.map(([name, status]) => (
          <div class={`gate g-${status}`}>
            <span class="gn">{name}</span>
            <span class="gs">{status.replace("_", " ")}</span>
          </div>
        ))
      }
    </div>
    <p class="fineprint">
      Gates are derived public status, not raw proof. A <b>metric</b> pass is advance-verified; a{" "}
      <b>ship</b> pass additionally requires a live SuperDoc-vs-Word layout proof.
    </p>
  </section>

  <section>
    <div class="lbl">Provenance</div>
    <dl class="prov">
      {
        record.candidateLicenseSource && (
          <Fragment>
            <dt>license source</dt>
            <dd>{record.candidateLicenseSource}</dd>
          </Fragment>
        )
      }
      <dt>measurement refs</dt>
      <dd>{record.measurementRefs.join(", ")}</dd>
      <dt>export rule</dt>
      <dd>{record.exportRule}</dd>
    </dl>
    <p class="fineprint">
      No proprietary font binaries or raw proprietary metric tables are stored. Measurements record
      the oracle environment as a label and reproduce against your own licensed fonts.
    </p>
  </section>
</Base>

<style>
  .faceverdicts {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .fv {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 8px 12px;
  }
  .fvname {
    font-size: 12px;
    color: var(--ink2);
    min-width: 64px;
  }
  .exceptions {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .exceptions li {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--v-cell);
    border-radius: 8px;
    padding: 10px 14px;
  }
  .exceptions .mono {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink);
    display: block;
  }
  .exceptions .exnote {
    font-size: 13px;
    color: var(--ink2);
    margin-top: 4px;
    display: block;
    line-height: 1.5;
  }
  .head {
    padding: 40px 0 8px;
  }
  .back {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink2);
    text-decoration: none;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 18px;
  }
  h1 {
    font-size: clamp(32px, 6vw, 46px);
    letter-spacing: -0.03em;
    margin: 8px 0 0;
  }
  .lead {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    font-size: 18px;
    margin-top: 14px;
  }
  .notes {
    color: var(--ink2);
    max-width: 70ch;
    margin-top: 14px;
    line-height: 1.6;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .fact {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .fact .k {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink3);
  }
  .fact .v {
    margin-top: 8px;
    font-size: 16px;
  }
  .fact .v.mono {
    font-family: var(--mono);
    font-size: 14px;
  }

  .gates {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .gate {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 8px 14px;
    background: var(--surface);
    font-family: var(--mono);
    font-size: 12px;
    display: flex;
    gap: 8px;
    align-items: baseline;
  }
  .gate .gn {
    color: var(--ink2);
  }
  .gate .gs {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .g-pass .gs {
    color: var(--v-safe);
  }
  .g-fail .gs {
    color: var(--v-clay);
  }
  .g-not_run .gs {
    color: var(--ink3);
  }

  .prov {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 18px;
    font-size: 13.5px;
  }
  .prov dt {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink3);
    align-self: baseline;
  }
  .prov dd {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink);
    overflow-wrap: anywhere;
  }
  @media (max-width: 520px) {
    .prov {
      grid-template-columns: 1fr;
      gap: 2px 0;
    }
    .prov dd {
      margin-bottom: 10px;
    }
  }
  .fineprint {
    font-size: 12px;
    color: var(--ink3);
    margin-top: 14px;
    max-width: 72ch;
    line-height: 1.55;
  }
</style>
