{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@docfonts/core": ["../../packages/core/src/index.ts"],
      "@docfonts/registry": ["../../packages/registry/src/index.ts"],
      "@docfonts/docx-fonts": ["../../packages/docx-fonts/src/index.ts"],
      "@docfonts/font-metadata": ["../../packages/font-metadata/src/index.ts"]
    }
  }
}
