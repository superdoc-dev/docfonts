{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@docfonts/fallbacks": ["./packages/fallbacks/src/index.ts"]
    }
  },
  "include": ["packages/fallbacks/**/*.ts", "tools/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/dist"]
}
